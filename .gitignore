# Git 忽略文件

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv
venv/
ENV/

# 环境变量（包含敏感信息）
.env
.env.local
.env.*.local

# 数据库和配置
*.db
*.sqlite
*.json
!.gitignore
!.env.example

# 日志
*.log

# 临时文件
*.bak
*.tmp
*.broken

# Dashboard
dashboard/*.bak
dashboard/*.broken
dashboard/index.html.v2

# 敏感信息
authorized_users.json
task-state.json
companies/
cookie_pool.json
remote_access.json
improvement_config.json
dashboard_token.txt

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
*.sh
*.patch
*.bundle
*.tar.gz
